{
  "mcpServers": {
    "aitl-js": {
      "command": "npm",
      "args": ["--prefix", "/ABSOLUTE/PATH/TO/AITL-Harness-JS", "run", "mcp", "--silent"],
      "env": {
        "MONGODB_URI": "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aitl?appName=<app>",
        "MONGODB_DB": "aitl",
        "EMBEDDING_PROVIDER": "local",
        "EMBEDDING_MODEL": "Xenova/all-MiniLM-L6-v2",
        "EMBEDDING_DIMS": "384",
        "AITL_MCP_LOG_FILE": "logs/aitl-raytracer-mcp.log"
      }
    }
  }
}
